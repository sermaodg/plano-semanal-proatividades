/* Reset e Base */
:root {
    --primary: rgb(105, 36, 255);
    --primary-hover: rgb(85, 20, 220);
    --text-dark: #111111;
    --text-main: #444444;
    --text-muted: #777777;
    --bg-light: #f4f4f7;
    --bg-white: #ffffff;
    --error: #e74c3c;
    --success: #2ecc71;
    --radius: 14px;
    --shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    --shadow-hover: 0 8px 30px rgba(105, 36, 255, 0.15);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', Arial, sans-serif;
    color: var(--text-main);
    background-color: var(--bg-white);
    /* Leve textura "papel sulfite" com ruído SVG em data URI */
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noiseFilter'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.8' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noiseFilter)' opacity='0.02'/%3E%3C/svg%3E");
    line-height: 1.6;
    overflow-x: hidden;
    scroll-behavior: smooth;
}

h1,
h2,
h3,
h4 {
    color: var(--text-dark);
    line-height: 1.2;
    font-weight: 700;
}

a {
    text-decoration: none;
    color: inherit;
}

ul {
    list-style: none;
}

/* Layout */
.container {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
}

section {
    padding: 80px 0;
}

.bg-light {
    background-color: var(--bg-light);
}

/* Utilitários */
.card-shadow {
    background: var(--bg-white);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.section-header {
    text-align: center;
    margin-bottom: 48px;
}

.section-header h2 {
    font-size: 2rem;
    margin-bottom: 12px;
}

.section-header p {
    font-size: 1.125rem;
    color: var(--text-muted);
}

.center-btn {
    text-align: center;
}

.mt-4 {
    margin-top: 2rem;
}

.mt-auto {
    margin-top: auto;
}

.w-100 {
    width: 100%;
}

.hide-mobile {
    display: none;
}

@media (min-width: 768px) {
    .hide-mobile {
        display: block;
    }
}

/* Botões */
button,
.btn-primary,
.btn-outline {
    display: inline-block;
    padding: 14px 28px;
    border-radius: var(--radius);
    font-size: 1rem;
    font-weight: 600;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
}

.btn-primary {
    background-color: var(--primary);
    color: white;
}

.btn-primary:hover {
    background-color: var(--primary-hover);
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
}

.btn-outline {
    background-color: transparent;
    color: var(--primary);
    border: 2px solid var(--primary);
}

.btn-outline:hover {
    background-color: var(--primary);
    color: white;
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
}

/* Header */
.header {
    padding: 20px 0;
    position: sticky;
    top: 0;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    z-index: 100;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

.header-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.logo {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.25rem;
    color: var(--text-dark);
}

.header .btn-outline {
    padding: 8px 20px;
    font-size: 0.875rem;
}

/* Hero Section */
.hero {
    padding: 60px 0;
    overflow: hidden;
}

.hero-content {
    display: flex;
    flex-direction: column;
    gap: 48px;
    align-items: center;
}

.hero-text {
    text-align: center;
    max-width: 700px;
}

.hero h1 {
    font-size: 2.25rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 24px;
}

.subheadline {
    font-size: 1.125rem;
    color: var(--text-muted);
    margin-bottom: 40px;
}

.hero-cta-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.microtext {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-dark);
}

.microcopy {
    font-size: 0.75rem;
    color: var(--text-muted);
}

.hero-visual {
    position: relative;
    width: 100%;
    max-width: 400px;
    aspect-ratio: 4/5;
    margin: 0 auto;
}

.image-slideshow {
    width: 100%;
    height: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    position: relative;
    box-shadow: var(--shadow);
}

.image-slideshow img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
    opacity: 0;
    transition: opacity 1s ease-in-out;
}

.image-slideshow img.active {
    opacity: 1;
}

/* floating decorations */
.float-decor,
.float-decor-alt {
    position: absolute;
    font-size: 24px;
    z-index: 2;
    filter: drop-shadow(0 4px 6px rgba(0, 0, 0, 0.1));
}

.floating {
    animation: float 6s ease-in-out infinite;
}

.float-decor {
    animation: floatDecor 4s ease-in-out infinite;
}

.float-decor-alt {
    animation: floatDecor 5s ease-in-out infinite reverse;
}

@keyframes float {

    0%,
    100% {
        transform: translateY(0);
    }

    50% {
        transform: translateY(-10px);
    }
}

@keyframes floatDecor {

    0%,
    100% {
        transform: translateY(0) rotate(0deg);
    }

    50% {
        transform: translateY(-8px) rotate(5deg);
    }
}

@media (min-width: 992px) {
    .hero-content {
        flex-direction: row;
        justify-content: space-between;
        align-items: center;
        text-align: left;
    }

    .hero-text {
        text-align: left;
        flex: 1;
        max-width: 550px;
    }

    .hero h1 {
        font-size: 3rem;
    }

    .hero-cta-group {
        align-items: flex-start;
    }

    .hero-visual {
        flex: 1;
        max-width: 450px;
    }
}

/* Video Section */
.video-wrapper {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #000;
    margin: 0 auto;
}

.video-wrapper.vertical-video {
    width: 100%;
    max-width: 360px;
    aspect-ratio: 9 / 16;
}

.video-wrapper video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    background: #000;
}

.play-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.2), rgba(0, 0, 0, 0.55));
    border: 0;
    cursor: pointer;
    z-index: 2;
}

.play-btn {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 40px;
    background: var(--primary);
    color: #fff;
    padding-left: 6px;
    /* Ajuste visual do ícone */
    box-shadow: 0 0 0 0 rgba(105, 36, 255, 0.7);
    animation: vturb-pulse 1.5s cubic-bezier(0.66, 0, 0, 1) infinite;
}

@keyframes vturb-pulse {
    0% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(105, 36, 255, 0.7);
    }

    70% {
        transform: scale(1.05);
        box-shadow: 0 0 0 25px rgba(105, 36, 255, 0);
    }

    100% {
        transform: scale(0.95);
        box-shadow: 0 0 0 0 rgba(105, 36, 255, 0);
    }
}

.mute-btn-container {
    position: absolute;
    right: 12px;
    top: 12px;
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 10px 12px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(0, 0, 0, 0.45);
    color: #fff;
    cursor: pointer;
    z-index: 3;
    transition: background 0.2s;
}

.mute-btn-container:hover {
    background: rgba(0, 0, 0, 0.65);
}

.progress-container {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 6px;
    background: rgba(255, 255, 255, 0.15);
    z-index: 3;
}

.progress-bar {
    height: 100%;
    width: 0%;
    background: rgba(255, 255, 255, 0.85);
    transform-origin: left;
}

.video-fallback {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: center;
    justify-content: center;
    background: #0b0b0b;
    color: #fff;
    padding: 22px;
    text-align: center;
    z-index: 10;
}

/* Pain Section */
.pain-content {
    padding: 40px 24px;
    max-width: 800px;
    margin: 0 auto;
}

.pain-content h2 {
    text-align: center;
    font-size: 1.75rem;
    margin-bottom: 32px;
}

.pain-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 24px;
}

.pain-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 1.05rem;
}

.pain-list li svg {
    flex-shrink: 0;
    margin-top: 2px;
}

.pain-conclusion {
    text-align: center;
    font-size: 1.125rem;
    padding-top: 24px;
    border-top: 1px solid #eaeaea;
}

@media (min-width: 768px) {
    .pain-content {
        padding: 56px 48px;
    }

    .pain-list li {
        font-size: 1.125rem;
    }
}

/* Features (Modules) Section */
.features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
}

@media (min-width: 768px) {
    .features-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

@media (min-width: 992px) {
    .features-grid {
        grid-template-columns: repeat(3, 1fr);
    }
}

.feature-card {
    padding: 32px 24px;
    text-align: center;
    position: relative;
    border: 1px solid rgba(0, 0, 0, 0.03);
}

.feature-card:hover {
    transform: translateY(-4px);
    border-color: rgba(105, 36, 255, 0.2);
}

.feature-icon {
    font-size: 2.5rem;
    margin-bottom: 20px;
}

.feature-card h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
}

.feature-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
}

.highlight-card {
    border: 2px solid rgba(105, 36, 255, 0.1);
    background: linear-gradient(180deg, #fff, #faf8ff);
}

.badge {
    position: absolute;
    top: 16px;
    right: 16px;
    background-color: var(--primary);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

/* Visual Proofs */
.proofs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
}

@media (min-width: 768px) {
    .proofs-grid {
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }
}

.proof-card {
    aspect-ratio: 3/4;
    border-radius: var(--radius);
    overflow: hidden;
    background-color: #e2e2e8;
    /* fallback color */
}

.placeholder-img {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #f4f4f7, #e2e2e8);
    color: var(--text-muted);
    font-size: 0.875rem;
    font-weight: 500;
}

/* Plans Section */
.plans-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    max-width: 800px;
    margin: 0 auto 32px;
}

@media (min-width: 768px) {
    .plans-grid {
        grid-template-columns: 1fr 1fr;
        align-items: stretch;
    }
}

.plan-card {
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(0, 0, 0, 0.05);
    position: relative;
    background-color: var(--bg-white);
}

.plan-card.featured {
    border: 3px solid var(--primary);
    transform: scale(1.02);
    box-shadow: 0 15px 40px rgba(105, 36, 255, 0.2);
}

@media (min-width: 768px) {
    .plan-card.featured {
        transform: scale(1.05);
        /* slightly larger on desktop */
        z-index: 2;
    }
}

.featured-badge {
    position: absolute;
    top: -14px;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--primary);
    color: white;
    padding: 4px 16px;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
}

.plan-name {
    font-size: 1.25rem;
    margin-bottom: 12px;
}

.plan-price {
    font-size: 3rem;
    font-weight: 800;
    color: var(--text-dark);
    margin-bottom: 4px;
    line-height: 1;
}

.plan-price span {
    font-size: 1.5rem;
}

.plan-type {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 24px;
}

.plan-benefits-highlight {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 32px;
}

.benefit-item {
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--success);
    background-color: rgba(46, 204, 113, 0.1);
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: lowercase;
}

.plan-features {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 40px;
    flex: 1;
    /* Pushes button to bottom */
}

.plan-features li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
}

.plan-features li svg {
    flex-shrink: 0;
    margin-top: 2px;
}

.plan-feature-blocked {
    opacity: 0.5;
    text-decoration: line-through;
    cursor: not-allowed;
}

.plan-microcopy {
    display: block;
    text-align: center;
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 12px;
    font-weight: 500;
}


.trust-text {
    text-align: center;
    font-size: 0.875rem;
    color: var(--text-muted);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
}

.trust-text a:not(.btn-instagram-discreet) {
    color: var(--primary);
    text-decoration: underline;
}

.btn-instagram-discreet {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    background-color: transparent;
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 20px;
    color: var(--text-main);
    font-weight: 500;
    font-size: 0.85rem;
    transition: all 0.2s ease;
    text-decoration: none;
}

.btn-instagram-discreet:hover {
    background-color: rgba(0, 0, 0, 0.03);
    border-color: rgba(0, 0, 0, 0.2);
    color: var(--text-dark);
    transform: translateY(-1px);
}

/* FAQ */
.faq-accordion {
    max-width: 700px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.faq-item {
    background-color: var(--bg-white);
    border-radius: var(--radius);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    overflow: hidden;
}

.faq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px;
    background: none;
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text-dark);
    text-align: left;
}

.faq-question .icon {
    transition: transform 0.3s ease;
}

.faq-item.active .icon {
    transform: rotate(180deg);
}

.faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-in-out;
}

.faq-answer p {
    padding: 0 24px 24px;
    color: var(--text-main);
}

/* Footer */
.footer {
    background-color: #111;
    color: #fff;
    padding: 60px 0 40px;
    text-align: center;
}

.footer-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
}

.footer-logo {
    font-weight: 800;
    font-size: 1.25rem;
}

.footer-disclaimer {
    color: #888;
    font-size: 0.875rem;
    max-width: 600px;
}

.footer-links {
    display: flex;
    gap: 24px;
    font-size: 0.875rem;
    color: #aaa;
}

.footer-links a:hover {
    color: white;
}

/* Modal */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
    z-index: 1000;
    align-items: center;
    justify-content: center;
    padding: 24px;
    opacity: 0;
    transition: opacity 0.3s ease;
}

.modal.show {
    opacity: 1;
}

.modal-content {
    background-color: var(--bg-white);
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    padding: 32px;
    position: relative;
    border-radius: var(--radius);
    transform: translateY(20px);
    transition: transform 0.3s ease;
}

.modal.show .modal-content {
    transform: translateY(0);
}

.modal-content h2 {
    margin-bottom: 24px;
}

.close-modal {
    position: absolute;
    top: 24px;
    right: 24px;
    font-size: 1.5rem;
    font-weight: bold;
    color: var(--text-muted);
    cursor: pointer;
    line-height: 1;
}

.close-modal:hover {
    color: var(--text-dark);
}

/* Animations Core */
.fade-in-up {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.fade-in-up.visible {
    opacity: 1;
    transform: translateY(0);
}

.scroll-reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

.scroll-reveal.visible {
    opacity: 1;
    transform: translateY(0);
}

/* =========================================
   QUIZ STYLES
   ========================================= */

.quiz-container {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    background-color: var(--bg-white);
}

.quiz-step {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s ease-in-out;
}

.quiz-step.active {
    opacity: 1;
    transform: translateY(0);
}

.step-content {
    animation: fadeIn 0.8s forwards;
}

@keyframes fadeIn {
    from {
        opacity: 0;
        transform: translateY(10px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.max-w-400 {
    max-width: 400px;
}

.max-w-600 {
    max-width: 600px;
}

.max-w-800 {
    max-width: 800px;
}

.mx-auto {
    margin-left: auto;
    margin-right: auto;
}

.mt-1 {
    margin-top: 0.25rem;
}

.mt-2 {
    margin-top: 0.5rem;
}

.mt-3 {
    margin-top: 1rem;
}

.mt-4 {
    margin-top: 1.5rem;
}

.mt-5 {
    margin-top: 3rem;
}

.mb-1 {
    margin-bottom: 0.25rem;
}

.mb-2 {
    margin-bottom: 0.5rem;
}

.mb-3 {
    margin-bottom: 1rem;
}

.mb-4 {
    margin-bottom: 1.5rem;
}

.mb-5 {
    margin-bottom: 3rem;
}

.pt-1 {
    padding-top: 0.25rem;
}

.pt-2 {
    padding-top: 0.5rem;
}

.pt-3 {
    padding-top: 1rem;
}

.pt-4 {
    padding-top: 1.5rem;
}

.pt-5 {
    padding-top: 3rem;
}

.pb-1 {
    padding-bottom: 0.25rem;
}

.pb-2 {
    padding-bottom: 0.5rem;
}

.pb-3 {
    padding-bottom: 1rem;
}

.pb-4 {
    padding-bottom: 1.5rem;
}

.pb-5 {
    padding-bottom: 3rem;
}

.text-center {
    text-align: center;
}

.text-left {
    text-align: left;
}

.font-bold {
    font-weight: 700;
}

.w-100 {
    width: 100%;
}

.block {
    display: block;
}

/* Mobile Overflow Fixes */
@media (max-width: 600px) {

    html,
    body {
        overflow-x: hidden;
        width: 100vw;
        max-width: 100%;
    }

    .container {
        padding: 0 16px !important;
    }

    .plan-card,
    .plan-card.featured {
        padding: 24px 16px !important;
        transform: scale(1) !important;
    }
}